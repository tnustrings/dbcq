toInt converts a byte slice to an int. this is needed when variable length numeric sql types get returned as []uint8.

taken from https://go.dev/play/p/eECOVBhWmlH

see https://forum.golangbridge.org/t/converting-single-byte-slice-to-int/8646/3

func toInt(s []byte) int {
	var b [8]byte
	copy(b[8-len(s):], s)
	return int(binary.BigEndian.Uint64(b[:]))
}
